{
  "name": "@squadronleader/jwax",
  "version": "1.1.1",
  "description": "CLI tool for querying JSON files with SQL",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "jwax": "bin/jwax.js"
  },
  "files": [
    "dist",
    "bin/jwax.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "dev": "ts-node bin/jwax.ts",
    "test": "node ../../scripts/check-native-sqlite.js --warn-only && jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "cli-table3": "^0.6.0",
    "commander": "^12.1.0",
    "sql.js": "^1.14.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.0.0",
    "@types/sql.js": "^1.4.9",
    "jest": "^29.5.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "tsup": "^8.5.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "json",
    "sql",
    "query",
    "sqlite",
    "cli",
    "database",
    "repl"
  ],
  "author": "squadronleader <contact@jwax.simplelogin.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/squadronleader/jwax"
  },
  "homepage": "https://github.com/squadronleader/jwax#readme",
  "bugs": {
    "url": "https://github.com/squadronleader/jwax/issues"
  }
}
